{
  "name": "hms-cypress",
  "version": "1.0.0",
  "description": "E2E tests for HMS Frontend using Cypress",
  "main": "index.js",
  "scripts": {
    "test": "cypress run --spec 'cypress/e2e/**/*.cy.js'",
    "test:local": "cypress run --baseUrl http://localhost:30006 --spec 'cypress/e2e/**/*.cy.js'",
    "test:open": "cypress open --baseUrl http://localhost:30006",
    "test:production": "cypress run --baseUrl https://digitalhms-momentum.vercel.app --env apiUrl=https://hms-api-eight.vercel.app --spec 'cypress/e2e/smoke.cy.js'",
    "test:production:open": "cypress open --baseUrl https://digitalhms-momentum.vercel.app --env apiUrl=https://hms-api-eight.vercel.app",
    "test:reports": "open mochawesome-report/mochawesome.html"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "cypress": "^15.0.0",
    "cypress-real-events": "^1.15.0",
    "mochawesome": "^7.1.3",
    "mochawesome-merge": "^4.3.0",
    "mochawesome-report-generator": "^6.2.0"
  }
}
